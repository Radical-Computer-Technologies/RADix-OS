#!/usr/bin/env bash
#
# provenance (pre-commit): refuse to create a commit under a disallowed AI
# co-author identity. Match terms are base64-encoded (see verify-provenance.sh).
#
# Enable once per clone:  git config core.hooksPath .githooks
set -euo pipefail

PATTERN="$(printf '%s' 'Y2xhdWRlfGFudGhyb3BpYw==' | base64 -d)"
fail=0

check() {
    local label="$1" value="$2"
    [ -n "$value" ] || return 0
    if printf '%s' "$value" | grep -qiE "$PATTERN"; then
        echo "provenance: blocked -- ${label} carries a disallowed co-author identity: '${value}'" >&2
        fail=1
    fi
}

check "author name"     "${GIT_AUTHOR_NAME:-$(git config user.name || true)}"
check "author email"    "${GIT_AUTHOR_EMAIL:-$(git config user.email || true)}"
check "committer name"  "${GIT_COMMITTER_NAME:-$(git config user.name || true)}"
check "committer email" "${GIT_COMMITTER_EMAIL:-$(git config user.email || true)}"

if [ "$fail" -ne 0 ]; then
    echo "provenance: commit rejected. Set a valid identity and retry." >&2
    exit 1
fi
