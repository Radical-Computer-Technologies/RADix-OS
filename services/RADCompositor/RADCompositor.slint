export component RadOsShell inherits Window {
    in property <string> backend: "";
    in property <string> status: "";
    in property <string> terminal: "";
    in property <bool> applications_open: false;
    in property <bool> terminal_open: true;
    in property <bool> terminal_loading: false;
    in property <int> terminal_window_id: 0;
    in property <string> terminal_window_title: "Terminal";
    in property <float> terminal_window_x: 134;
    in property <float> terminal_window_y: 110;
    in property <float> terminal_window_width: 640;
    in property <float> terminal_window_height: 380;
    in property <bool> terminal_window_focused: true;

    callback toggle_applications();
    callback launch_terminal();
    callback escape_pressed();
    callback focus_terminal_window();
    callback close_terminal_window();
    callback move_terminal_window(float, float);
    callback resize_terminal_window(float, float);

    title: "RAD OS";
    width: 640px;
    height: 360px;
    background: #07111f;

    Rectangle {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: 38px;
        background: #10233f;

        Image {
            x: 12px;
            y: 7px;
            width: 70px;
            height: 32px;
            source: @image-url("assets/RadLogoWhiteHeader.png");
            image-fit: contain;
        }

        Text {
            x: 94px;
            y: 9px;
            text: "OS";
            color: #f8fafc;
            font-size: 17px;
            font-weight: 700;
        }
    }

    Rectangle {
        x: 0px;
        y: 38px;
        width: 86px;
        height: 82px;
        background: root.applications_open ? #1d4ed8 : #0b1729;
        border-color: root.applications_open ? #93c5fd : #1d4ed8;
        border-width: 1px;

        Text {
            x: 0px;
            y: 10px;
            width: parent.width;
            horizontal-alignment: center;
            text: "Apps";
            color: #f8fafc;
            font-size: 15px;
            font-weight: 700;
        }

        Text {
            x: 0px;
            y: 36px;
            width: parent.width;
            horizontal-alignment: center;
            text: "Applications";
            color: #bfdbfe;
            font-size: 11px;
        }

        TouchArea {
            clicked => { root.toggle_applications(); }
        }
    }

    Rectangle {
        x: 96px;
        y: 38px;
        width: 190px;
        height: root.applications_open ? 92px : 0px;
        background: #0f172a;
        border-color: #38bdf8;
        border-width: root.applications_open ? 1px : 0px;
        visible: root.applications_open;

        Text {
            x: 12px;
            y: 10px;
            width: parent.width - 20px;
            text: "Applications";
            color: #f8fafc;
            font-size: 13px;
            font-weight: 700;
        }

        Rectangle {
            x: 8px;
            y: 36px;
            width: parent.width - 16px;
            height: 42px;
            background: #111827;
            border-color: #334155;
            border-width: 1px;

            Text {
                x: 10px;
                y: 12px;
                text: "Terminal";
                color: #d1fae5;
                font-size: 13px;
            }

            TouchArea {
                clicked => { root.launch_terminal(); }
            }
        }
    }

    terminal-window := Rectangle {
        x: root.terminal_window_x * 1px;
        y: root.terminal_window_y * 1px;
        width: root.terminal_window_width * 1px;
        height: root.terminal_window_height * 1px;
        background: #020617;
        border-color: root.terminal_window_focused ? #38bdf8 : #475569;
        border-width: root.terminal_open ? 1px : 0px;
        visible: root.terminal_open;

        Rectangle {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: 28px;
            background: root.terminal_window_focused ? #0f2d4d : #111827;

            Text {
                x: 10px;
                y: 7px;
                width: parent.width - 48px;
                text: root.terminal_window_title;
                color: #f8fafc;
                font-size: 13px;
                font-weight: 700;
                overflow: elide;
            }

            title-drag := TouchArea {
                x: 0px;
                y: 0px;
                width: parent.width - 32px;
                height: parent.height;
                clicked => { root.focus_terminal_window(); }
                moved => {
                    if (self.pressed) {
                        root.move_terminal_window(
                            (self.mouse-x - self.pressed-x) / 1px,
                            (self.mouse-y - self.pressed-y) / 1px
                        );
                    }
                }
                mouse-cursor: MouseCursor.grab;
            }

            close-button := TouchArea {
                x: parent.width - 28px;
                y: 2px;
                width: 24px;
                height: 24px;
                clicked => { root.close_terminal_window(); }
                mouse-cursor: MouseCursor.pointer;

                Text {
                    x: 0px;
                    y: 2px;
                    width: parent.width;
                    horizontal-alignment: center;
                    text: "x";
                    color: parent.has-hover ? #fecaca : #f8fafc;
                    font-size: 13px;
                    font-weight: 700;
                }
            }
        }

        TouchArea {
            x: 0px;
            y: 28px;
            width: parent.width;
            height: parent.height - 28px;
            clicked => { root.focus_terminal_window(); }
        }

        Text {
            x: 10px;
            y: 42px;
            width: parent.width - 20px;
            text: "Launching Terminal...";
            color: #fef3c7;
            font-size: 14px;
            visible: root.terminal_loading;
        }

        Text {
            x: 10px;
            y: 38px;
            width: parent.width - 20px;
            height: parent.height - 46px;
            text: root.terminal;
            color: #d1fae5;
            font-family: "monospace";
            font-size: 13px;
            wrap: word-wrap;
            overflow: clip;
            visible: !root.terminal_loading;
        }

        resize-handle := TouchArea {
            x: parent.width - 20px;
            y: parent.height - 20px;
            width: 20px;
            height: 20px;
            moved => {
                if (self.pressed) {
                    root.resize_terminal_window(
                        (self.mouse-x - self.pressed-x) / 1px,
                        (self.mouse-y - self.pressed-y) / 1px
                    );
                }
            }
            mouse-cursor: MouseCursor.nwse-resize;

            Rectangle {
                x: 14px;
                y: 6px;
                width: 2px;
                height: 10px;
                background: #64748b;
            }
            Rectangle {
                x: 6px;
                y: 14px;
                width: 10px;
                height: 2px;
                background: #64748b;
            }
        }
    }

    FocusScope {
        key-pressed(event) => {
            if (event.text == Key.Escape) {
                root.escape_pressed();
                accept
            } else {
                reject
            }
        }
    }
}

export component RadDesktopSurface inherits Window {
    in property <string> backend: "";
    in property <string> status: "";
    in property <float> surface_width: 640;
    in property <float> surface_height: 360;
    in property <bool> applications_open: false;
    in property <bool> terminal_open: false;
    in property <bool> file_explorer_open: false;
    // Dock right-click "Close" dropdown: 0=none, 1=terminal, 2=files.
    in property <int> dock_menu_app: 0;

    callback toggle_applications();
    callback launch_terminal();
    callback launch_file_explorer();
    callback escape_pressed();
    callback dock_context_menu(int);
    callback dock_dismiss();
    callback focus_window_from_dock(int);
    callback close_terminal_from_dock();
    callback close_file_explorer_from_dock();

    title: "RAD Desktop";
    width: root.surface_width * 1px;
    height: root.surface_height * 1px;
    background: @linear-gradient(160deg, #0c1c33 0%, #071322 55%, #050e19 100%);

    Rectangle {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: 38px;
        background: @linear-gradient(180deg, #12263f 0%, #0a1a2e 100%);

        Image {
            x: 12px;
            y: 7px;
            width: 70px;
            height: 32px;
            source: @image-url("assets/RadLogoWhiteHeader.png");
            image-fit: contain;
        }

        Text {
            x: 94px;
            y: 9px;
            text: "OS";
            color: #f8fafc;
            font-size: 17px;
            font-weight: 700;
        }
    }

    // Left dock: a gradient panel (black at the top fading to light gray at the bottom)
    // spanning below the top bar. It holds the Apps launcher and icons for the currently
    // open apps; the icons render on top of the gradient.
    Rectangle {
        x: 0px;
        y: 38px;
        width: 86px;
        height: parent.height - 38px;
        background: @linear-gradient(180deg, #050506 0%, #17171a 32%, #4b4b53 70%, #b9b9c1 100%);

        // Apps launcher toggle (top of the dock).
        Rectangle {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: 82px;
            background: root.applications_open ? #1d4ed8 : #0b1729;
            border-color: root.applications_open ? #93c5fd : #1d4ed8;
            border-width: 1px;

            Text {
                x: 0px;
                y: 10px;
                width: parent.width;
                horizontal-alignment: center;
                text: "Apps";
                color: #f8fafc;
                font-size: 15px;
                font-weight: 700;
            }

            Text {
                x: 0px;
                y: 36px;
                width: parent.width;
                horizontal-alignment: center;
                text: "Applications";
                color: #bfdbfe;
                font-size: 11px;
            }

            TouchArea {
                clicked => { root.toggle_applications(); }
            }
        }

        // Open-app icon: the terminal, a black tile with a ">_" prompt glyph, shown while
        // the terminal window is open. Left-click focuses/raises the window; right-click
        // opens the "Close" dropdown.
        Rectangle {
            x: 13px;
            y: 94px;
            width: 60px;
            height: 60px;
            visible: root.terminal_open;
            background: #000000;
            border-radius: 9px;
            border-color: #2f2f33;
            border-width: 1px;

            Text {
                x: 0px;
                y: 0px;
                width: parent.width;
                height: parent.height;
                horizontal-alignment: center;
                vertical-alignment: center;
                text: ">_";
                color: #4ade80;
                font-size: 24px;
                font-weight: 800;
                font-family: "monospace";
            }

            TouchArea {
                clicked => { root.focus_window_from_dock(1); }
                pointer-event(event) => {
                    if (event.kind == PointerEventKind.down && event.button == PointerEventButton.right) {
                        root.dock_context_menu(1);
                    }
                }
                mouse-cursor: MouseCursor.pointer;
            }
        }

        // Open-app icon: the file explorer, a folder-style tile with "Fs", shown while the
        // explorer window is open.
        Rectangle {
            x: 13px;
            y: 164px;
            width: 60px;
            height: 60px;
            visible: root.file_explorer_open;
            background: #1e293b;
            border-radius: 9px;
            border-color: #38bdf8;
            border-width: 1px;

            Text {
                x: 0px;
                y: 0px;
                width: parent.width;
                height: parent.height;
                horizontal-alignment: center;
                vertical-alignment: center;
                text: "Fs";
                color: #7dd3fc;
                font-size: 22px;
                font-weight: 800;
                font-family: "monospace";
            }

            TouchArea {
                clicked => { root.focus_window_from_dock(2); }
                pointer-event(event) => {
                    if (event.kind == PointerEventKind.down && event.button == PointerEventButton.right) {
                        root.dock_context_menu(2);
                    }
                }
                mouse-cursor: MouseCursor.pointer;
            }
        }
    }

    Rectangle {
        x: 96px;
        y: 38px;
        width: 190px;
        height: root.applications_open ? 140px : 0px;
        background: #0f172a;
        border-color: #38bdf8;
        border-width: root.applications_open ? 1px : 0px;
        visible: root.applications_open;

        Text {
            x: 12px;
            y: 10px;
            width: parent.width - 20px;
            text: "Applications";
            color: #f8fafc;
            font-size: 13px;
            font-weight: 700;
        }

        Rectangle {
            x: 8px;
            y: 36px;
            width: parent.width - 16px;
            height: 42px;
            background: #111827;
            border-color: #334155;
            border-width: 1px;

            Text {
                x: 10px;
                y: 12px;
                text: "Terminal";
                color: #d1fae5;
                font-size: 13px;
            }

            TouchArea {
                clicked => { root.launch_terminal(); }
            }
        }

        Rectangle {
            x: 8px;
            y: 84px;
            width: parent.width - 16px;
            height: 42px;
            background: #111827;
            border-color: #334155;
            border-width: 1px;

            Text {
                x: 10px;
                y: 12px;
                text: "Files";
                color: #bae6fd;
                font-size: 13px;
            }

            TouchArea {
                clicked => { root.launch_file_explorer(); }
            }
        }
    }

    // Backdrop: any click outside an open dock dropdown dismisses it. Declared before the
    // dropdowns so the dropdown row stays clickable on top of it.
    TouchArea {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        visible: root.dock_menu_app != 0;
        clicked => { root.dock_dismiss(); }
    }

    // Dock right-click "Close" dropdown for the terminal icon (anchored to its right).
    Rectangle {
        x: 60px;
        y: 132px;
        width: 96px;
        height: 30px;
        visible: root.dock_menu_app == 1;
        background: #0b1729;
        border-color: #38bdf8;
        border-width: 1px;
        border-radius: 6px;

        Text {
            x: 12px;
            y: 7px;
            text: "Close";
            color: #fecaca;
            font-size: 13px;
        }

        TouchArea {
            clicked => { root.close_terminal_from_dock(); }
            mouse-cursor: MouseCursor.pointer;
        }
    }

    // Dock right-click "Close" dropdown for the file-explorer icon.
    Rectangle {
        x: 60px;
        y: 202px;
        width: 96px;
        height: 30px;
        visible: root.dock_menu_app == 2;
        background: #0b1729;
        border-color: #38bdf8;
        border-width: 1px;
        border-radius: 6px;

        Text {
            x: 12px;
            y: 7px;
            text: "Close";
            color: #fecaca;
            font-size: 13px;
        }

        TouchArea {
            clicked => { root.close_file_explorer_from_dock(); }
            mouse-cursor: MouseCursor.pointer;
        }
    }

    FocusScope {
        key-pressed(event) => {
            if (event.text == Key.Escape) {
                root.escape_pressed();
                accept
            } else {
                reject
            }
        }
    }
}

export component RadTerminalSurface inherits Window {
    in property <string> terminal: "";
    in property <bool> terminal_loading: false;
    in property <string> terminal_window_title: "Terminal";
    in property <bool> terminal_window_focused: true;
    in property <float> surface_width: 640;
    in property <float> surface_height: 380;

    callback focus_terminal_window();
    callback close_terminal_window();
    callback move_terminal_window(float, float);
    callback resize_terminal_window(float, float);
    callback escape_pressed();

    title: "RAD Terminal";
    width: root.surface_width * 1px;
    height: root.surface_height * 1px;
    background: #020617;

    Rectangle {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        background: @linear-gradient(180deg, #0a1626 0%, #040d1a 100%);
        border-color: root.terminal_window_focused ? #38bdf8 : #2a3a4f;
        border-width: root.terminal_window_focused ? 1.5px : 1px;
        border-radius: 8px;
        clip: true;

        Rectangle {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: 28px;
            background: root.terminal_window_focused
                ? @linear-gradient(180deg, #1b3e64 0%, #0f2942 100%)
                : @linear-gradient(180deg, #132a41 0%, #0a1c30 100%);

            // Focus accent underline along the base of the title bar.
            Rectangle {
                x: 0px;
                y: parent.height - 1px;
                width: parent.width;
                height: 1px;
                background: root.terminal_window_focused ? #38bdf8 : #1e2f45;
            }

            Text {
                x: 10px;
                y: 7px;
                width: parent.width - 48px;
                text: root.terminal_window_title;
                color: #f8fafc;
                font-size: 13px;
                font-weight: 700;
                overflow: elide;
            }

            title-drag := TouchArea {
                x: 0px;
                y: 0px;
                width: parent.width - 32px;
                height: parent.height;
                clicked => { root.focus_terminal_window(); }
                moved => {
                    if (self.pressed) {
                        root.move_terminal_window(
                            (self.mouse-x - self.pressed-x) / 1px,
                            (self.mouse-y - self.pressed-y) / 1px
                        );
                    }
                }
                mouse-cursor: MouseCursor.grab;
            }

            close-button := TouchArea {
                x: parent.width - 28px;
                y: 2px;
                width: 24px;
                height: 24px;
                clicked => { root.close_terminal_window(); }
                mouse-cursor: MouseCursor.pointer;

                Text {
                    x: 0px;
                    y: 2px;
                    width: parent.width;
                    horizontal-alignment: center;
                    text: "x";
                    color: parent.has-hover ? #fecaca : #f8fafc;
                    font-size: 13px;
                    font-weight: 700;
                }
            }
        }

        TouchArea {
            x: 0px;
            y: 28px;
            width: parent.width;
            height: parent.height - 28px;
            clicked => { root.focus_terminal_window(); }
        }

        Text {
            x: 10px;
            y: 42px;
            width: parent.width - 20px;
            text: "Launching Terminal...";
            color: #fef3c7;
            font-size: 14px;
            visible: root.terminal_loading;
        }

        Text {
            x: 10px;
            y: 38px;
            width: parent.width - 20px;
            height: parent.height - 46px;
            text: root.terminal;
            color: #d1fae5;
            font-family: "monospace";
            font-size: 13px;
            wrap: word-wrap;
            overflow: clip;
            visible: !root.terminal_loading;
        }

        resize-handle := TouchArea {
            x: parent.width - 20px;
            y: parent.height - 20px;
            width: 20px;
            height: 20px;
            moved => {
                if (self.pressed) {
                    root.resize_terminal_window(
                        (self.mouse-x - self.pressed-x) / 1px,
                        (self.mouse-y - self.pressed-y) / 1px
                    );
                }
            }
            mouse-cursor: MouseCursor.nwse-resize;

            Rectangle {
                x: 14px;
                y: 6px;
                width: 2px;
                height: 10px;
                background: #64748b;
            }
            Rectangle {
                x: 6px;
                y: 14px;
                width: 10px;
                height: 2px;
                background: #64748b;
            }
        }
    }

    // Escape must reach the terminal (forwarded to the PTY as the ESC byte in C++), so
    // the window does NOT swallow it here -- it never closes the window and never routes
    // to the desktop's escape close path.
    FocusScope {
        key-pressed(event) => {
            reject
        }
    }
}

// File explorer window. A near-duplicate of RadTerminalSurface (title bar with drag-to-move
// and close, focus-on-click body, resize handle). The body shows a single multi-line Text
// bound to `entries` (newline-joined listing) -- Repeater-free so the freestanding kernel
// links (-nostdlib / -fno-exceptions cannot pull in std::make_shared for Slint models).
export struct RadFileEntry {
    name: string,
    is-dir: bool,
}

export component RadFileExplorerSurface inherits Window {
    in property <string> entries: "";
    in property <[RadFileEntry]> entries-model: [];
    in property <string> current-path: "/";
    in property <bool> explorer_loading: false;
    in property <string> explorer_window_title: "Files";
    in property <bool> explorer_window_focused: true;
    in property <float> surface_width: 560;
    in property <float> surface_height: 360;

    callback focus_explorer_window();
    callback close_explorer_window();
    callback move_explorer_window(float, float);
    callback resize_explorer_window(float, float);
    callback navigate(int);
    callback escape_pressed();

    title: "RAD Files";
    width: root.surface_width * 1px;
    height: root.surface_height * 1px;
    background: #020617;

    Rectangle {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        background: @linear-gradient(180deg, #0a1626 0%, #040d1a 100%);
        border-color: root.explorer_window_focused ? #38bdf8 : #2a3a4f;
        border-width: root.explorer_window_focused ? 1.5px : 1px;
        border-radius: 8px;
        clip: true;

        Rectangle {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: 28px;
            background: root.explorer_window_focused
                ? @linear-gradient(180deg, #1b3e64 0%, #0f2942 100%)
                : @linear-gradient(180deg, #132a41 0%, #0a1c30 100%);

            Rectangle {
                x: 0px;
                y: parent.height - 1px;
                width: parent.width;
                height: 1px;
                background: root.explorer_window_focused ? #38bdf8 : #1e2f45;
            }

            Text {
                x: 10px;
                y: 7px;
                width: parent.width - 48px;
                text: root.explorer_window_title;
                color: #f8fafc;
                font-size: 13px;
                font-weight: 700;
                overflow: elide;
            }

            title-drag := TouchArea {
                x: 0px;
                y: 0px;
                width: parent.width - 32px;
                height: parent.height;
                clicked => { root.focus_explorer_window(); }
                moved => {
                    if (self.pressed) {
                        root.move_explorer_window(
                            (self.mouse-x - self.pressed-x) / 1px,
                            (self.mouse-y - self.pressed-y) / 1px
                        );
                    }
                }
                mouse-cursor: MouseCursor.grab;
            }

            close-button := TouchArea {
                x: parent.width - 28px;
                y: 2px;
                width: 24px;
                height: 24px;
                clicked => { root.close_explorer_window(); }
                mouse-cursor: MouseCursor.pointer;

                Text {
                    x: 0px;
                    y: 2px;
                    width: parent.width;
                    horizontal-alignment: center;
                    text: "x";
                    color: parent.has-hover ? #fecaca : #f8fafc;
                    font-size: 13px;
                    font-weight: 700;
                }
            }
        }

        TouchArea {
            x: 0px;
            y: 28px;
            width: parent.width;
            height: parent.height - 28px;
            clicked => { root.focus_explorer_window(); }
        }

        // Current-path breadcrumb.
        Text {
            x: 10px;
            y: 34px;
            width: parent.width - 20px;
            text: root.current-path;
            color: #7dd3fc;
            font-size: 12px;
            font-weight: 700;
            font-family: "monospace";
            overflow: elide;
        }

        // Directory listing: one clickable row per entry with a folder/file icon.
        Rectangle {
            x: 6px;
            y: 52px;
            width: parent.width - 12px;
            height: parent.height - 60px;
            clip: true;

            VerticalLayout {
                alignment: start;
                for entry[i] in root.entries-model : Rectangle {
                    height: 24px;
                    background: row-touch.has-hover ? #16324f : transparent;
                    border-radius: 4px;

                    // Folder icon: amber body with a tab.
                    Rectangle {
                        visible: entry.is-dir;
                        x: 8px;
                        y: 7px;
                        width: 16px;
                        height: 11px;
                        background: #f5c451;
                        border-radius: 2px;
                        Rectangle {
                            x: 0px;
                            y: -3px;
                            width: 7px;
                            height: 4px;
                            background: #f5c451;
                            border-radius: 1px;
                        }
                    }
                    // File icon: light page.
                    Rectangle {
                        visible: !entry.is-dir;
                        x: 10px;
                        y: 5px;
                        width: 12px;
                        height: 15px;
                        background: #cbd5e1;
                        border-radius: 2px;
                    }

                    Text {
                        x: 34px;
                        width: parent.width - 42px;
                        height: parent.height;
                        text: entry.name;
                        color: entry.is-dir ? #93c5fd : #e2e8f0;
                        font-size: 13px;
                        font-family: "monospace";
                        vertical-alignment: center;
                        overflow: elide;
                    }

                    row-touch := TouchArea {
                        clicked => { root.navigate(i); }
                        mouse-cursor: entry.is-dir ? MouseCursor.pointer : MouseCursor.default;
                    }
                }
            }
        }

        resize-handle := TouchArea {
            x: parent.width - 20px;
            y: parent.height - 20px;
            width: 20px;
            height: 20px;
            moved => {
                if (self.pressed) {
                    root.resize_explorer_window(
                        (self.mouse-x - self.pressed-x) / 1px,
                        (self.mouse-y - self.pressed-y) / 1px
                    );
                }
            }
            mouse-cursor: MouseCursor.nwse-resize;

            Rectangle {
                x: 14px;
                y: 6px;
                width: 2px;
                height: 10px;
                background: #64748b;
            }
            Rectangle {
                x: 6px;
                y: 14px;
                width: 10px;
                height: 2px;
                background: #64748b;
            }
        }
    }

    FocusScope {
        key-pressed(event) => {
            if (event.text == Key.Escape) {
                root.escape_pressed();
                accept
            } else {
                reject
            }
        }
    }
}
