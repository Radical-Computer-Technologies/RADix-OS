import { Button, LineEdit, TextEdit } from "std-widgets.slint";

export component RadOsShell inherits Window {
    in property <string> backend: "";
    in property <string> status: "";
    in property <string> terminal: "";
    in property <bool> applications_open: false;
    in property <bool> terminal_open: true;
    in property <bool> terminal_loading: false;
    in property <int> terminal_window_id: 0;
    in property <string> terminal_window_title: "Terminal";
    in property <float> terminal_window_x: 134;
    in property <float> terminal_window_y: 110;
    in property <float> terminal_window_width: 640;
    in property <float> terminal_window_height: 380;
    in property <bool> terminal_window_focused: true;

    callback toggle_applications();
    callback launch_terminal();
    callback escape_pressed();
    callback focus_terminal_window();
    callback close_terminal_window();
    callback move_terminal_window(float, float);
    callback resize_terminal_window(float, float);

    title: "RAD OS";
    width: 640px;
    height: 360px;
    background: #07111f;

    Rectangle {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: 38px;
        background: #10233f;

        Image {
            x: 12px;
            y: 7px;
            width: 70px;
            height: 32px;
            source: @image-url("assets/RadLogoWhiteHeader.png");
            image-fit: contain;
        }

        Text {
            x: 94px;
            y: 9px;
            text: "OS";
            color: #f8fafc;
            font-size: 17px;
            font-weight: 700;
        }
    }

    Rectangle {
        x: 0px;
        y: 38px;
        width: 86px;
        height: 82px;
        background: root.applications_open ? #1d4ed8 : #0b1729;
        border-color: root.applications_open ? #93c5fd : #1d4ed8;
        border-width: 1px;

        Text {
            x: 0px;
            y: 10px;
            width: parent.width;
            horizontal-alignment: center;
            text: "Apps";
            color: #f8fafc;
            font-size: 15px;
            font-weight: 700;
        }

        Text {
            x: 0px;
            y: 36px;
            width: parent.width;
            horizontal-alignment: center;
            text: "Applications";
            color: #bfdbfe;
            font-size: 11px;
        }

        TouchArea {
            clicked => { root.toggle_applications(); }
        }
    }

    Rectangle {
        x: 96px;
        y: 38px;
        width: 190px;
        height: root.applications_open ? 92px : 0px;
        background: #0f172a;
        border-color: #38bdf8;
        border-width: root.applications_open ? 1px : 0px;
        visible: root.applications_open;

        Text {
            x: 12px;
            y: 10px;
            width: parent.width - 20px;
            text: "Applications";
            color: #f8fafc;
            font-size: 13px;
            font-weight: 700;
        }

        Rectangle {
            x: 8px;
            y: 36px;
            width: parent.width - 16px;
            height: 42px;
            background: #111827;
            border-color: #334155;
            border-width: 1px;

            Text {
                x: 10px;
                y: 12px;
                text: "Terminal";
                color: #d1fae5;
                font-size: 13px;
            }

            TouchArea {
                clicked => { root.launch_terminal(); }
            }
        }
    }

    terminal-window := Rectangle {
        x: root.terminal_window_x * 1px;
        y: root.terminal_window_y * 1px;
        width: root.terminal_window_width * 1px;
        height: root.terminal_window_height * 1px;
        background: #020617;
        border-color: root.terminal_window_focused ? #38bdf8 : #475569;
        border-width: root.terminal_open ? 1px : 0px;
        visible: root.terminal_open;

        Rectangle {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: 28px;
            background: root.terminal_window_focused ? #0f2d4d : #111827;

            Text {
                x: 10px;
                y: 7px;
                width: parent.width - 48px;
                text: root.terminal_window_title;
                color: #f8fafc;
                font-size: 13px;
                font-weight: 700;
                overflow: elide;
            }

            title-drag := TouchArea {
                x: 0px;
                y: 0px;
                width: parent.width - 32px;
                height: parent.height;
                clicked => { root.focus_terminal_window(); }
                moved => {
                    if (self.pressed) {
                        root.move_terminal_window(
                            (self.mouse-x - self.pressed-x) / 1px,
                            (self.mouse-y - self.pressed-y) / 1px
                        );
                    }
                }
                mouse-cursor: MouseCursor.grab;
            }

            close-button := TouchArea {
                x: parent.width - 28px;
                y: 2px;
                width: 24px;
                height: 24px;
                clicked => { root.close_terminal_window(); }
                mouse-cursor: MouseCursor.pointer;

                Text {
                    x: 0px;
                    y: 2px;
                    width: parent.width;
                    horizontal-alignment: center;
                    text: "x";
                    color: parent.has-hover ? #fecaca : #f8fafc;
                    font-size: 13px;
                    font-weight: 700;
                }
            }
        }

        TouchArea {
            x: 0px;
            y: 28px;
            width: parent.width;
            height: parent.height - 28px;
            clicked => { root.focus_terminal_window(); }
        }

        Text {
            x: 10px;
            y: 42px;
            width: parent.width - 20px;
            text: "Launching Terminal...";
            color: #fef3c7;
            font-size: 14px;
            visible: root.terminal_loading;
        }

        Text {
            x: 10px;
            y: 38px;
            width: parent.width - 20px;
            height: parent.height - 46px;
            text: root.terminal;
            color: #d1fae5;
            font-family: "monospace";
            font-size: 13px;
            wrap: word-wrap;
            overflow: clip;
            visible: !root.terminal_loading;
        }

        resize-handle := TouchArea {
            x: parent.width - 20px;
            y: parent.height - 20px;
            width: 20px;
            height: 20px;
            moved => {
                if (self.pressed) {
                    root.resize_terminal_window(
                        (self.mouse-x - self.pressed-x) / 1px,
                        (self.mouse-y - self.pressed-y) / 1px
                    );
                }
            }
            mouse-cursor: MouseCursor.nwse-resize;

            Rectangle {
                x: 14px;
                y: 6px;
                width: 2px;
                height: 10px;
                background: #64748b;
            }
            Rectangle {
                x: 6px;
                y: 14px;
                width: 10px;
                height: 2px;
                background: #64748b;
            }
        }
    }

    FocusScope {
        key-pressed(event) => {
            if (event.text == Key.Escape) {
                root.escape_pressed();
                accept
            } else {
                reject
            }
        }
    }
}

// A dock icon for a currently-open app. kind: 1=terminal, 2=files. app-id is the window id.
export struct RadDockIcon {
    app-id: int,
    kind: int,
}

export component RadDesktopSurface inherits Window {
    in property <string> backend: "";
    in property <string> status: "";
    in property <float> surface_width: 640;
    in property <float> surface_height: 360;
    in property <bool> applications_open: false;
    in property <bool> terminal_open: false;
    in property <bool> file_explorer_open: false;
    in property <bool> text_editor_open: false;
    // Open-app dock icons, in open order (first opened at the top).
    in property <[RadDockIcon]> dock-icons: [];
    // Dock right-click "Close" dropdown: 0=none, else the app-id whose menu is open.
    in property <int> dock_menu_app: 0;
    // Y (px) of the icon whose Close dropdown is open, so the single dropdown can anchor to it.
    in property <float> dock_menu_y: 132;

    callback toggle_applications();
    callback launch_terminal();
    callback launch_file_explorer();
    callback launch_text_editor();
    callback escape_pressed();
    callback dock_context_menu(int);
    callback dock_dismiss();
    callback focus_window_from_dock(int);
    callback close_app_from_dock(int);

    title: "RAD Desktop";
    width: root.surface_width * 1px;
    height: root.surface_height * 1px;
    background: @linear-gradient(160deg, #0c1c33 0%, #071322 55%, #050e19 100%);

    Rectangle {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: 38px;
        background: @linear-gradient(180deg, #12263f 0%, #0a1a2e 100%);

        Image {
            x: 12px;
            y: 7px;
            width: 70px;
            height: 32px;
            source: @image-url("assets/RadLogoWhiteHeader.png");
            image-fit: contain;
        }

        Text {
            x: 94px;
            y: 9px;
            text: "OS";
            color: #f8fafc;
            font-size: 17px;
            font-weight: 700;
        }
    }

    // Left dock: a gradient panel (black at the top fading to light gray at the bottom)
    // spanning below the top bar. It holds the Apps launcher and icons for the currently
    // open apps; the icons render on top of the gradient.
    Rectangle {
        x: 0px;
        y: 38px;
        width: 86px;
        height: parent.height - 38px;
        background: @linear-gradient(180deg, #050506 0%, #17171a 32%, #4b4b53 70%, #b9b9c1 100%);

        // Apps launcher toggle (top of the dock).
        Rectangle {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: 82px;
            background: root.applications_open ? #1d4ed8 : #0b1729;
            border-color: root.applications_open ? #93c5fd : #1d4ed8;
            border-width: 1px;

            Text {
                x: 0px;
                y: 10px;
                width: parent.width;
                horizontal-alignment: center;
                text: "Apps";
                color: #f8fafc;
                font-size: 15px;
                font-weight: 700;
            }

            Text {
                x: 0px;
                y: 36px;
                width: parent.width;
                horizontal-alignment: center;
                text: "Applications";
                color: #bfdbfe;
                font-size: 11px;
            }

            TouchArea {
                clicked => { root.toggle_applications(); }
            }
        }

        // Open-app icons, in open order: the first app opened sits at the top, the next
        // below it, etc. Left-click focuses/raises the window; right-click opens the "Close"
        // dropdown. kind 1=terminal (black ">_" tile), 2=file explorer (gray folder),
        // 3=text editor (white paper sheet with text lines).
        for icon[idx] in root.dock-icons : Rectangle {
            x: 13px;
            y: 94px + idx * 70px;
            width: 60px;
            height: 60px;
            background: icon.kind == 1 ? #000000 : #1e293b;
            border-radius: 9px;
            border-color: icon.kind == 1 ? #2f2f33 : #38bdf8;
            border-width: 1px;

            // kind 1: terminal ">_" glyph.
            Text {
                visible: icon.kind == 1;
                x: 0px;
                y: 0px;
                width: parent.width;
                height: parent.height;
                horizontal-alignment: center;
                vertical-alignment: center;
                text: ">_";
                color: #4ade80;
                font-size: 24px;
                font-weight: 800;
                font-family: "monospace";
            }

            // kind 2: gray folder -- a body Rectangle with a small tab on its top-left.
            Rectangle {
                visible: icon.kind == 2;
                x: 14px;
                y: 22px;
                width: 32px;
                height: 22px;
                background: #9ca3af;
                border-radius: 3px;

                Rectangle {
                    x: 0px;
                    y: -5px;
                    width: 14px;
                    height: 6px;
                    background: #6b7280;
                    border-radius: 2px;
                }
            }

            // kind 3: white paper sheet with 3-4 thin gray text lines of varying length.
            Rectangle {
                visible: icon.kind == 3;
                x: 18px;
                y: 15px;
                width: 24px;
                height: 30px;
                background: #f8fafc;
                border-radius: 2px;

                Rectangle {
                    x: 4px;
                    y: 5px;
                    width: 16px;
                    height: 2px;
                    background: #94a3b8;
                }
                Rectangle {
                    x: 4px;
                    y: 11px;
                    width: 12px;
                    height: 2px;
                    background: #94a3b8;
                }
                Rectangle {
                    x: 4px;
                    y: 17px;
                    width: 15px;
                    height: 2px;
                    background: #94a3b8;
                }
                Rectangle {
                    x: 4px;
                    y: 23px;
                    width: 9px;
                    height: 2px;
                    background: #94a3b8;
                }
            }

            TouchArea {
                clicked => { root.focus_window_from_dock(icon.app-id); }
                pointer-event(event) => {
                    if (event.kind == PointerEventKind.down && event.button == PointerEventButton.right) {
                        root.dock_context_menu(icon.app-id);
                    }
                }
                mouse-cursor: MouseCursor.pointer;
            }
        }
    }

    Rectangle {
        x: 96px;
        y: 38px;
        width: 190px;
        height: root.applications_open ? 188px : 0px;
        background: #0f172a;
        border-color: #38bdf8;
        border-width: root.applications_open ? 1px : 0px;
        visible: root.applications_open;

        Text {
            x: 12px;
            y: 10px;
            width: parent.width - 20px;
            text: "Applications";
            color: #f8fafc;
            font-size: 13px;
            font-weight: 700;
        }

        Rectangle {
            x: 8px;
            y: 36px;
            width: parent.width - 16px;
            height: 42px;
            background: #111827;
            border-color: #334155;
            border-width: 1px;

            Text {
                x: 10px;
                y: 12px;
                text: "Terminal";
                color: #d1fae5;
                font-size: 13px;
            }

            TouchArea {
                clicked => { root.launch_terminal(); }
            }
        }

        Rectangle {
            x: 8px;
            y: 84px;
            width: parent.width - 16px;
            height: 42px;
            background: #111827;
            border-color: #334155;
            border-width: 1px;

            Text {
                x: 10px;
                y: 12px;
                text: "Files";
                color: #bae6fd;
                font-size: 13px;
            }

            TouchArea {
                clicked => { root.launch_file_explorer(); }
            }
        }

        Rectangle {
            x: 8px;
            y: 132px;
            width: parent.width - 16px;
            height: 42px;
            background: #111827;
            border-color: #334155;
            border-width: 1px;

            Text {
                x: 10px;
                y: 12px;
                text: "Editor";
                color: #fde68a;
                font-size: 13px;
            }

            TouchArea {
                clicked => { root.launch_text_editor(); }
            }
        }
    }

    // Backdrop: any click outside an open dock dropdown dismisses it. Declared before the
    // dropdowns so the dropdown row stays clickable on top of it.
    TouchArea {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        visible: root.dock_menu_app != 0;
        clicked => { root.dock_dismiss(); }
    }

    // Dock right-click "Close" dropdown, anchored to the right of whichever open-app icon
    // was right-clicked (dock_menu_y is that icon's Y, supplied by the shell).
    Rectangle {
        x: 60px;
        y: root.dock_menu_y * 1px;
        width: 96px;
        height: 30px;
        visible: root.dock_menu_app != 0;
        background: #0b1729;
        border-color: #38bdf8;
        border-width: 1px;
        border-radius: 6px;

        Text {
            x: 12px;
            y: 7px;
            text: "Close";
            color: #fecaca;
            font-size: 13px;
        }

        TouchArea {
            clicked => { root.close_app_from_dock(root.dock_menu_app); }
            mouse-cursor: MouseCursor.pointer;
        }
    }

    FocusScope {
        key-pressed(event) => {
            if (event.text == Key.Escape) {
                root.escape_pressed();
                accept
            } else {
                reject
            }
        }
    }
}

export component RadTerminalSurface inherits Window {
    in property <string> terminal: "";
    in property <bool> terminal_loading: false;
    in property <string> terminal_window_title: "Terminal";
    in property <bool> terminal_window_focused: true;
    in property <float> surface_width: 640;
    in property <float> surface_height: 380;

    callback focus_terminal_window();
    callback close_terminal_window();
    callback move_terminal_window(float, float);
    callback resize_terminal_window(float, float);
    callback escape_pressed();

    title: "RAD Terminal";
    width: root.surface_width * 1px;
    height: root.surface_height * 1px;
    background: #020617;

    Rectangle {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        background: @linear-gradient(180deg, #0a1626 0%, #040d1a 100%);
        border-color: root.terminal_window_focused ? #38bdf8 : #2a3a4f;
        border-width: root.terminal_window_focused ? 1.5px : 1px;
        border-radius: 8px;
        clip: true;

        Rectangle {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: 28px;
            background: root.terminal_window_focused
                ? @linear-gradient(180deg, #1b3e64 0%, #0f2942 100%)
                : @linear-gradient(180deg, #132a41 0%, #0a1c30 100%);

            // Focus accent underline along the base of the title bar.
            Rectangle {
                x: 0px;
                y: parent.height - 1px;
                width: parent.width;
                height: 1px;
                background: root.terminal_window_focused ? #38bdf8 : #1e2f45;
            }

            Text {
                x: 10px;
                y: 7px;
                width: parent.width - 48px;
                text: root.terminal_window_title;
                color: #f8fafc;
                font-size: 13px;
                font-weight: 700;
                overflow: elide;
            }

            title-drag := TouchArea {
                x: 0px;
                y: 0px;
                width: parent.width - 32px;
                height: parent.height;
                clicked => { root.focus_terminal_window(); }
                moved => {
                    if (self.pressed) {
                        root.move_terminal_window(
                            (self.mouse-x - self.pressed-x) / 1px,
                            (self.mouse-y - self.pressed-y) / 1px
                        );
                    }
                }
                mouse-cursor: MouseCursor.grab;
            }

            close-button := TouchArea {
                x: parent.width - 28px;
                y: 2px;
                width: 24px;
                height: 24px;
                clicked => { root.close_terminal_window(); }
                mouse-cursor: MouseCursor.pointer;

                Text {
                    x: 0px;
                    y: 2px;
                    width: parent.width;
                    horizontal-alignment: center;
                    text: "x";
                    color: parent.has-hover ? #fecaca : #f8fafc;
                    font-size: 13px;
                    font-weight: 700;
                }
            }
        }

        TouchArea {
            x: 0px;
            y: 28px;
            width: parent.width;
            height: parent.height - 28px;
            clicked => { root.focus_terminal_window(); }
        }

        Text {
            x: 10px;
            y: 42px;
            width: parent.width - 20px;
            text: "Launching Terminal...";
            color: #fef3c7;
            font-size: 14px;
            visible: root.terminal_loading;
        }

        Text {
            x: 10px;
            y: 38px;
            width: parent.width - 20px;
            height: parent.height - 46px;
            text: root.terminal;
            color: #d1fae5;
            font-family: "monospace";
            font-size: 13px;
            wrap: word-wrap;
            overflow: clip;
            visible: !root.terminal_loading;
        }

        resize-handle := TouchArea {
            x: parent.width - 20px;
            y: parent.height - 20px;
            width: 20px;
            height: 20px;
            moved => {
                if (self.pressed) {
                    root.resize_terminal_window(
                        (self.mouse-x - self.pressed-x) / 1px,
                        (self.mouse-y - self.pressed-y) / 1px
                    );
                }
            }
            mouse-cursor: MouseCursor.nwse-resize;

            Rectangle {
                x: 14px;
                y: 6px;
                width: 2px;
                height: 10px;
                background: #64748b;
            }
            Rectangle {
                x: 6px;
                y: 14px;
                width: 10px;
                height: 2px;
                background: #64748b;
            }
        }
    }

    // Escape must reach the terminal (forwarded to the PTY as the ESC byte in C++), so
    // the window does NOT swallow it here -- it never closes the window and never routes
    // to the desktop's escape close path.
    FocusScope {
        key-pressed(event) => {
            reject
        }
    }
}

// File explorer window. A near-duplicate of RadTerminalSurface (title bar with drag-to-move
// and close, focus-on-click body, resize handle). The body shows a single multi-line Text
// bound to `entries` (newline-joined listing) -- Repeater-free so the freestanding kernel
// links (-nostdlib / -fno-exceptions cannot pull in std::make_shared for Slint models).
export struct RadFileEntry {
    name: string,
    is-dir: bool,
}

export component RadFileExplorerSurface inherits Window {
    in property <string> entries: "";
    in property <[RadFileEntry]> entries-model: [];
    in property <string> current-path: "/";
    in property <bool> explorer_loading: false;
    in property <string> explorer_window_title: "Files";
    in property <bool> explorer_window_focused: true;
    in property <float> surface_width: 560;
    in property <float> surface_height: 360;

    callback focus_explorer_window();
    callback close_explorer_window();
    callback move_explorer_window(float, float);
    callback resize_explorer_window(float, float);
    callback navigate(int);
    callback escape_pressed();

    title: "RAD Files";
    width: root.surface_width * 1px;
    height: root.surface_height * 1px;
    background: #020617;

    Rectangle {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        background: @linear-gradient(180deg, #0a1626 0%, #040d1a 100%);
        border-color: root.explorer_window_focused ? #38bdf8 : #2a3a4f;
        border-width: root.explorer_window_focused ? 1.5px : 1px;
        border-radius: 8px;
        clip: true;

        Rectangle {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: 28px;
            background: root.explorer_window_focused
                ? @linear-gradient(180deg, #1b3e64 0%, #0f2942 100%)
                : @linear-gradient(180deg, #132a41 0%, #0a1c30 100%);

            Rectangle {
                x: 0px;
                y: parent.height - 1px;
                width: parent.width;
                height: 1px;
                background: root.explorer_window_focused ? #38bdf8 : #1e2f45;
            }

            Text {
                x: 10px;
                y: 7px;
                width: parent.width - 48px;
                text: root.explorer_window_title;
                color: #f8fafc;
                font-size: 13px;
                font-weight: 700;
                overflow: elide;
            }

            title-drag := TouchArea {
                x: 0px;
                y: 0px;
                width: parent.width - 32px;
                height: parent.height;
                clicked => { root.focus_explorer_window(); }
                moved => {
                    if (self.pressed) {
                        root.move_explorer_window(
                            (self.mouse-x - self.pressed-x) / 1px,
                            (self.mouse-y - self.pressed-y) / 1px
                        );
                    }
                }
                mouse-cursor: MouseCursor.grab;
            }

            close-button := TouchArea {
                x: parent.width - 28px;
                y: 2px;
                width: 24px;
                height: 24px;
                clicked => { root.close_explorer_window(); }
                mouse-cursor: MouseCursor.pointer;

                Text {
                    x: 0px;
                    y: 2px;
                    width: parent.width;
                    horizontal-alignment: center;
                    text: "x";
                    color: parent.has-hover ? #fecaca : #f8fafc;
                    font-size: 13px;
                    font-weight: 700;
                }
            }
        }

        TouchArea {
            x: 0px;
            y: 28px;
            width: parent.width;
            height: parent.height - 28px;
            clicked => { root.focus_explorer_window(); }
        }

        // Current-path breadcrumb.
        Text {
            x: 10px;
            y: 34px;
            width: parent.width - 20px;
            text: root.current-path;
            color: #7dd3fc;
            font-size: 12px;
            font-weight: 700;
            font-family: "monospace";
            overflow: elide;
        }

        // Directory listing: one clickable row per entry with a folder/file icon.
        Rectangle {
            x: 6px;
            y: 52px;
            width: parent.width - 12px;
            height: parent.height - 60px;
            clip: true;

            VerticalLayout {
                alignment: start;
                for entry[i] in root.entries-model : Rectangle {
                    height: 24px;
                    background: row-touch.has-hover ? #16324f : transparent;
                    border-radius: 4px;

                    // Folder icon: amber body with a tab.
                    Rectangle {
                        visible: entry.is-dir;
                        x: 8px;
                        y: 7px;
                        width: 16px;
                        height: 11px;
                        background: #f5c451;
                        border-radius: 2px;
                        Rectangle {
                            x: 0px;
                            y: -3px;
                            width: 7px;
                            height: 4px;
                            background: #f5c451;
                            border-radius: 1px;
                        }
                    }
                    // File icon: light page.
                    Rectangle {
                        visible: !entry.is-dir;
                        x: 10px;
                        y: 5px;
                        width: 12px;
                        height: 15px;
                        background: #cbd5e1;
                        border-radius: 2px;
                    }

                    Text {
                        x: 34px;
                        width: parent.width - 42px;
                        height: parent.height;
                        text: entry.name;
                        color: entry.is-dir ? #93c5fd : #e2e8f0;
                        font-size: 13px;
                        font-family: "monospace";
                        vertical-alignment: center;
                        overflow: elide;
                    }

                    row-touch := TouchArea {
                        clicked => { root.navigate(i); }
                        mouse-cursor: entry.is-dir ? MouseCursor.pointer : MouseCursor.default;
                    }
                }
            }
        }

        resize-handle := TouchArea {
            x: parent.width - 20px;
            y: parent.height - 20px;
            width: 20px;
            height: 20px;
            moved => {
                if (self.pressed) {
                    root.resize_explorer_window(
                        (self.mouse-x - self.pressed-x) / 1px,
                        (self.mouse-y - self.pressed-y) / 1px
                    );
                }
            }
            mouse-cursor: MouseCursor.nwse-resize;

            Rectangle {
                x: 14px;
                y: 6px;
                width: 2px;
                height: 10px;
                background: #64748b;
            }
            Rectangle {
                x: 6px;
                y: 14px;
                width: 10px;
                height: 2px;
                background: #64748b;
            }
        }
    }

    FocusScope {
        key-pressed(event) => {
            if (event.text == Key.Escape) {
                root.escape_pressed();
                accept
            } else {
                reject
            }
        }
    }
}

// Text editor window. Chrome (title bar with drag-to-move + close, focus-on-click body,
// resize handle, borders) mirrors RadFileExplorerSurface. Content is a toolbar row (a
// LineEdit for the file path + Open/Save buttons) above a TextEdit that fills the body and
// is two-way bound to document-text; edits flow back to C++ via text_changed.
export component RadTextEditorSurface inherits Window {
    in-out property <string> document-text: "";
    in-out property <string> file-path: "/tmp/untitled.txt";
    in property <bool> editor_loading: false;
    in property <string> editor_window_title: "Editor";
    in property <bool> editor_window_focused: true;
    in property <float> surface_width: 700;
    in property <float> surface_height: 460;

    callback focus_editor_window();
    callback close_editor_window();
    callback move_editor_window(float, float);
    callback resize_editor_window(float, float);
    callback open_requested();
    callback save_requested(string);
    callback text_changed(string);
    callback path_changed(string);
    callback escape_pressed();

    // Focus the document editor so typed keys edit the text. Called from C++ when the editor
    // window gains focus / is opened.
    public function focus_document() {
        editor-text.focus();
    }

    title: "RAD Editor";
    width: root.surface_width * 1px;
    height: root.surface_height * 1px;
    background: #020617;
    forward-focus: editor-text;

    Rectangle {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        background: @linear-gradient(180deg, #0a1626 0%, #040d1a 100%);
        border-color: root.editor_window_focused ? #38bdf8 : #2a3a4f;
        border-width: root.editor_window_focused ? 1.5px : 1px;
        border-radius: 8px;
        clip: true;

        Rectangle {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: 28px;
            background: root.editor_window_focused
                ? @linear-gradient(180deg, #1b3e64 0%, #0f2942 100%)
                : @linear-gradient(180deg, #132a41 0%, #0a1c30 100%);

            Rectangle {
                x: 0px;
                y: parent.height - 1px;
                width: parent.width;
                height: 1px;
                background: root.editor_window_focused ? #38bdf8 : #1e2f45;
            }

            Text {
                x: 10px;
                y: 7px;
                width: parent.width - 48px;
                text: root.editor_window_title;
                color: #f8fafc;
                font-size: 13px;
                font-weight: 700;
                overflow: elide;
            }

            title-drag := TouchArea {
                x: 0px;
                y: 0px;
                width: parent.width - 32px;
                height: parent.height;
                clicked => { root.focus_editor_window(); }
                moved => {
                    if (self.pressed) {
                        root.move_editor_window(
                            (self.mouse-x - self.pressed-x) / 1px,
                            (self.mouse-y - self.pressed-y) / 1px
                        );
                    }
                }
                mouse-cursor: MouseCursor.grab;
            }

            close-button := TouchArea {
                x: parent.width - 28px;
                y: 2px;
                width: 24px;
                height: 24px;
                clicked => { root.close_editor_window(); }
                mouse-cursor: MouseCursor.pointer;

                Text {
                    x: 0px;
                    y: 2px;
                    width: parent.width;
                    horizontal-alignment: center;
                    text: "x";
                    color: parent.has-hover ? #fecaca : #f8fafc;
                    font-size: 13px;
                    font-weight: 700;
                }
            }
        }

        // Toolbar: file-path LineEdit + Open/Save buttons.
        HorizontalLayout {
            x: 8px;
            y: 34px;
            width: parent.width - 16px;
            height: 30px;
            spacing: 6px;

            path-input := LineEdit {
                text <=> root.file-path;
                placeholder-text: "/path/to/file";
                edited(text) => { root.path_changed(text); }
            }

            Button {
                text: "Open";
                clicked => { root.open_requested(); }
            }

            Button {
                text: "Save";
                clicked => { root.save_requested(root.file-path); }
            }
        }

        // Document editor: fills the rest of the body.
        editor-text := TextEdit {
            x: 8px;
            y: 70px;
            width: parent.width - 16px;
            height: parent.height - 82px;
            text <=> root.document-text;
            wrap: no-wrap;
            edited(text) => { root.text_changed(text); }
        }

        // Thin strip below the title bar (behind the toolbar) refocuses the window on click.
        TouchArea {
            x: 0px;
            y: 28px;
            width: parent.width;
            height: 6px;
            clicked => { root.focus_editor_window(); }
        }

        resize-handle := TouchArea {
            x: parent.width - 20px;
            y: parent.height - 20px;
            width: 20px;
            height: 20px;
            moved => {
                if (self.pressed) {
                    root.resize_editor_window(
                        (self.mouse-x - self.pressed-x) / 1px,
                        (self.mouse-y - self.pressed-y) / 1px
                    );
                }
            }
            mouse-cursor: MouseCursor.nwse-resize;

            Rectangle {
                x: 14px;
                y: 6px;
                width: 2px;
                height: 10px;
                background: #64748b;
            }
            Rectangle {
                x: 6px;
                y: 14px;
                width: 10px;
                height: 2px;
                background: #64748b;
            }
        }
    }
}
