export component RadOsShell inherits Window {
    in property <string> backend: "";
    in property <string> status: "";
    in property <string> terminal: "";
    in property <bool> applications_open: false;
    in property <bool> terminal_open: true;
    in property <bool> terminal_loading: false;
    in property <int> terminal_window_id: 0;
    in property <string> terminal_window_title: "Terminal";
    in property <float> terminal_window_x: 134;
    in property <float> terminal_window_y: 110;
    in property <float> terminal_window_width: 640;
    in property <float> terminal_window_height: 380;
    in property <bool> terminal_window_focused: true;

    callback toggle_applications();
    callback launch_terminal();
    callback escape_pressed();
    callback focus_terminal_window();
    callback close_terminal_window();
    callback move_terminal_window(float, float);
    callback resize_terminal_window(float, float);

    title: "RAD OS";
    width: 640px;
    height: 360px;
    background: #07111f;

    Rectangle {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: 38px;
        background: #10233f;

        Image {
            x: 12px;
            y: 7px;
            width: 70px;
            height: 32px;
            source: @image-url("assets/RadLogoWhiteHeader.png");
            image-fit: contain;
        }

        Text {
            x: 94px;
            y: 9px;
            text: "OS";
            color: #f8fafc;
            font-size: 17px;
            font-weight: 700;
        }
    }

    Rectangle {
        x: 0px;
        y: 38px;
        width: 86px;
        height: 82px;
        background: root.applications_open ? #1d4ed8 : #0b1729;
        border-color: root.applications_open ? #93c5fd : #1d4ed8;
        border-width: 1px;

        Text {
            x: 0px;
            y: 10px;
            width: parent.width;
            horizontal-alignment: center;
            text: "Apps";
            color: #f8fafc;
            font-size: 15px;
            font-weight: 700;
        }

        Text {
            x: 0px;
            y: 36px;
            width: parent.width;
            horizontal-alignment: center;
            text: "Applications";
            color: #bfdbfe;
            font-size: 11px;
        }

        TouchArea {
            clicked => { root.toggle_applications(); }
        }
    }

    Rectangle {
        x: 96px;
        y: 38px;
        width: 190px;
        height: root.applications_open ? 92px : 0px;
        background: #0f172a;
        border-color: #38bdf8;
        border-width: root.applications_open ? 1px : 0px;
        visible: root.applications_open;

        Text {
            x: 12px;
            y: 10px;
            width: parent.width - 20px;
            text: "Applications";
            color: #f8fafc;
            font-size: 13px;
            font-weight: 700;
        }

        Rectangle {
            x: 8px;
            y: 36px;
            width: parent.width - 16px;
            height: 42px;
            background: #111827;
            border-color: #334155;
            border-width: 1px;

            Text {
                x: 10px;
                y: 12px;
                text: "Terminal";
                color: #d1fae5;
                font-size: 13px;
            }

            TouchArea {
                clicked => { root.launch_terminal(); }
            }
        }
    }

    terminal-window := Rectangle {
        x: root.terminal_window_x * 1px;
        y: root.terminal_window_y * 1px;
        width: root.terminal_window_width * 1px;
        height: root.terminal_window_height * 1px;
        background: #020617;
        border-color: root.terminal_window_focused ? #38bdf8 : #475569;
        border-width: root.terminal_open ? 1px : 0px;
        visible: root.terminal_open;

        Rectangle {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: 28px;
            background: root.terminal_window_focused ? #0f2d4d : #111827;

            Text {
                x: 10px;
                y: 7px;
                width: parent.width - 48px;
                text: root.terminal_loading ? root.terminal_window_title : "Slint " + root.terminal_window_title;
                color: #f8fafc;
                font-size: 13px;
                font-weight: 700;
                overflow: elide;
            }

            title-drag := TouchArea {
                x: 0px;
                y: 0px;
                width: parent.width - 32px;
                height: parent.height;
                clicked => { root.focus_terminal_window(); }
                moved => {
                    if (self.pressed) {
                        root.move_terminal_window(
                            (self.mouse-x - self.pressed-x) / 1px,
                            (self.mouse-y - self.pressed-y) / 1px
                        );
                    }
                }
                mouse-cursor: MouseCursor.grab;
            }

            close-button := TouchArea {
                x: parent.width - 28px;
                y: 2px;
                width: 24px;
                height: 24px;
                clicked => { root.close_terminal_window(); }
                mouse-cursor: MouseCursor.pointer;

                Text {
                    x: 0px;
                    y: 2px;
                    width: parent.width;
                    horizontal-alignment: center;
                    text: "x";
                    color: parent.has-hover ? #fecaca : #f8fafc;
                    font-size: 13px;
                    font-weight: 700;
                }
            }
        }

        TouchArea {
            x: 0px;
            y: 28px;
            width: parent.width;
            height: parent.height - 28px;
            clicked => { root.focus_terminal_window(); }
        }

        Text {
            x: 10px;
            y: 42px;
            width: parent.width - 20px;
            text: "Launching Terminal...";
            color: #fef3c7;
            font-size: 14px;
            visible: root.terminal_loading;
        }

        Text {
            x: 10px;
            y: 38px;
            width: parent.width - 20px;
            height: parent.height - 46px;
            text: root.terminal;
            color: #d1fae5;
            font-family: "monospace";
            font-size: 13px;
            wrap: word-wrap;
            overflow: clip;
            visible: !root.terminal_loading;
        }

        resize-handle := TouchArea {
            x: parent.width - 20px;
            y: parent.height - 20px;
            width: 20px;
            height: 20px;
            moved => {
                if (self.pressed) {
                    root.resize_terminal_window(
                        (self.mouse-x - self.pressed-x) / 1px,
                        (self.mouse-y - self.pressed-y) / 1px
                    );
                }
            }
            mouse-cursor: MouseCursor.nwse-resize;

            Rectangle {
                x: 14px;
                y: 6px;
                width: 2px;
                height: 10px;
                background: #64748b;
            }
            Rectangle {
                x: 6px;
                y: 14px;
                width: 10px;
                height: 2px;
                background: #64748b;
            }
        }
    }

    FocusScope {
        key-pressed(event) => {
            if (event.text == Key.Escape) {
                root.escape_pressed();
                accept
            } else {
                reject
            }
        }
    }
}

export component RadDesktopSurface inherits Window {
    in property <string> backend: "";
    in property <string> status: "";
    in property <float> surface_width: 640;
    in property <float> surface_height: 360;
    in property <bool> applications_open: false;
    in property <bool> terminal_open: false;

    callback toggle_applications();
    callback launch_terminal();
    callback escape_pressed();

    title: "RAD Desktop";
    width: root.surface_width * 1px;
    height: root.surface_height * 1px;
    background: @linear-gradient(160deg, #0c1c33 0%, #071322 55%, #050e19 100%);

    Rectangle {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: 38px;
        background: @linear-gradient(180deg, #12263f 0%, #0a1a2e 100%);

        Image {
            x: 12px;
            y: 7px;
            width: 70px;
            height: 32px;
            source: @image-url("assets/RadLogoWhiteHeader.png");
            image-fit: contain;
        }

        Text {
            x: 94px;
            y: 9px;
            text: "OS";
            color: #f8fafc;
            font-size: 17px;
            font-weight: 700;
        }
    }

    // Left dock: a gradient panel (black at the top fading to light gray at the bottom)
    // spanning below the top bar. It holds the Apps launcher and icons for the currently
    // open apps; the icons render on top of the gradient.
    Rectangle {
        x: 0px;
        y: 38px;
        width: 86px;
        height: parent.height - 38px;
        background: @linear-gradient(180deg, #050506 0%, #17171a 32%, #4b4b53 70%, #b9b9c1 100%);

        // Apps launcher toggle (top of the dock).
        Rectangle {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: 82px;
            background: root.applications_open ? #1d4ed8 : #0b1729;
            border-color: root.applications_open ? #93c5fd : #1d4ed8;
            border-width: 1px;

            Text {
                x: 0px;
                y: 10px;
                width: parent.width;
                horizontal-alignment: center;
                text: "Apps";
                color: #f8fafc;
                font-size: 15px;
                font-weight: 700;
            }

            Text {
                x: 0px;
                y: 36px;
                width: parent.width;
                horizontal-alignment: center;
                text: "Applications";
                color: #bfdbfe;
                font-size: 11px;
            }

            TouchArea {
                clicked => { root.toggle_applications(); }
            }
        }

        // Open-app icon: the terminal, a black tile with a ">_" prompt glyph, shown while
        // the terminal window is open.
        Rectangle {
            x: 13px;
            y: 94px;
            width: 60px;
            height: 60px;
            visible: root.terminal_open;
            background: #000000;
            border-radius: 9px;
            border-color: #2f2f33;
            border-width: 1px;

            Text {
                x: 0px;
                y: 0px;
                width: parent.width;
                height: parent.height;
                horizontal-alignment: center;
                vertical-alignment: center;
                text: ">_";
                color: #4ade80;
                font-size: 24px;
                font-weight: 800;
                font-family: "monospace";
            }
        }
    }

    Rectangle {
        x: 96px;
        y: 38px;
        width: 190px;
        height: root.applications_open ? 92px : 0px;
        background: #0f172a;
        border-color: #38bdf8;
        border-width: root.applications_open ? 1px : 0px;
        visible: root.applications_open;

        Text {
            x: 12px;
            y: 10px;
            width: parent.width - 20px;
            text: "Applications";
            color: #f8fafc;
            font-size: 13px;
            font-weight: 700;
        }

        Rectangle {
            x: 8px;
            y: 36px;
            width: parent.width - 16px;
            height: 42px;
            background: #111827;
            border-color: #334155;
            border-width: 1px;

            Text {
                x: 10px;
                y: 12px;
                text: "Terminal";
                color: #d1fae5;
                font-size: 13px;
            }

            TouchArea {
                clicked => { root.launch_terminal(); }
            }
        }
    }

    FocusScope {
        key-pressed(event) => {
            if (event.text == Key.Escape) {
                root.escape_pressed();
                accept
            } else {
                reject
            }
        }
    }
}

export component RadTerminalSurface inherits Window {
    in property <string> terminal: "";
    in property <bool> terminal_loading: false;
    in property <string> terminal_window_title: "Terminal";
    in property <bool> terminal_window_focused: true;
    in property <float> surface_width: 640;
    in property <float> surface_height: 380;

    callback focus_terminal_window();
    callback close_terminal_window();
    callback move_terminal_window(float, float);
    callback resize_terminal_window(float, float);
    callback escape_pressed();

    title: "RAD Terminal";
    width: root.surface_width * 1px;
    height: root.surface_height * 1px;
    background: #020617;

    Rectangle {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        background: @linear-gradient(180deg, #0a1626 0%, #040d1a 100%);
        border-color: root.terminal_window_focused ? #38bdf8 : #2a3a4f;
        border-width: root.terminal_window_focused ? 1.5px : 1px;
        border-radius: 8px;
        clip: true;

        Rectangle {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: 28px;
            background: root.terminal_window_focused
                ? @linear-gradient(180deg, #1b3e64 0%, #0f2942 100%)
                : @linear-gradient(180deg, #132a41 0%, #0a1c30 100%);

            // Focus accent underline along the base of the title bar.
            Rectangle {
                x: 0px;
                y: parent.height - 1px;
                width: parent.width;
                height: 1px;
                background: root.terminal_window_focused ? #38bdf8 : #1e2f45;
            }

            Text {
                x: 10px;
                y: 7px;
                width: parent.width - 48px;
                text: root.terminal_loading ? root.terminal_window_title : "Slint " + root.terminal_window_title;
                color: #f8fafc;
                font-size: 13px;
                font-weight: 700;
                overflow: elide;
            }

            title-drag := TouchArea {
                x: 0px;
                y: 0px;
                width: parent.width - 32px;
                height: parent.height;
                clicked => { root.focus_terminal_window(); }
                moved => {
                    if (self.pressed) {
                        root.move_terminal_window(
                            (self.mouse-x - self.pressed-x) / 1px,
                            (self.mouse-y - self.pressed-y) / 1px
                        );
                    }
                }
                mouse-cursor: MouseCursor.grab;
            }

            close-button := TouchArea {
                x: parent.width - 28px;
                y: 2px;
                width: 24px;
                height: 24px;
                clicked => { root.close_terminal_window(); }
                mouse-cursor: MouseCursor.pointer;

                Text {
                    x: 0px;
                    y: 2px;
                    width: parent.width;
                    horizontal-alignment: center;
                    text: "x";
                    color: parent.has-hover ? #fecaca : #f8fafc;
                    font-size: 13px;
                    font-weight: 700;
                }
            }
        }

        TouchArea {
            x: 0px;
            y: 28px;
            width: parent.width;
            height: parent.height - 28px;
            clicked => { root.focus_terminal_window(); }
        }

        Text {
            x: 10px;
            y: 42px;
            width: parent.width - 20px;
            text: "Launching Terminal...";
            color: #fef3c7;
            font-size: 14px;
            visible: root.terminal_loading;
        }

        Text {
            x: 10px;
            y: 38px;
            width: parent.width - 20px;
            height: parent.height - 46px;
            text: root.terminal;
            color: #d1fae5;
            font-family: "monospace";
            font-size: 13px;
            wrap: word-wrap;
            overflow: clip;
            visible: !root.terminal_loading;
        }

        resize-handle := TouchArea {
            x: parent.width - 20px;
            y: parent.height - 20px;
            width: 20px;
            height: 20px;
            moved => {
                if (self.pressed) {
                    root.resize_terminal_window(
                        (self.mouse-x - self.pressed-x) / 1px,
                        (self.mouse-y - self.pressed-y) / 1px
                    );
                }
            }
            mouse-cursor: MouseCursor.nwse-resize;

            Rectangle {
                x: 14px;
                y: 6px;
                width: 2px;
                height: 10px;
                background: #64748b;
            }
            Rectangle {
                x: 6px;
                y: 14px;
                width: 10px;
                height: 2px;
                background: #64748b;
            }
        }
    }

    FocusScope {
        key-pressed(event) => {
            if (event.text == Key.Escape) {
                root.escape_pressed();
                accept
            } else {
                reject
            }
        }
    }
}
