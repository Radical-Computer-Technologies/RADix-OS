{
  "radbuild_schema": "2.0",
  "radbuild_version": "0.2.1",
  "project_name": "RADPx-OS",
  "systems": [
    {
      "id": "rad-x86-64-grub-terminal",
      "type": "os.radix",
      "name": "RADPx-OS x86_64 GRUB terminal VM image",
      "provider": "radix-os",
      "depends_on": [],
      "toolchain": {
        "architecture": "x86_64",
        "boot": "grub-multiboot2",
        "ui": "framebuffer-terminal"
      },
      "config": {
        "target": "x86_64-grub-terminal",
        "ui_profile": "terminal",
        "feature_chunks": [
          "kernel.core",
          "kernel.x86_64",
          "drivers.framebuffer",
          "drivers.input.ps2",
          "drivers.block.virtio",
          "drivers.net.virtio",
          "fs.ext4",
          "fs.fat",
          "services.radinit",
          "services.base-terminal",
          "userspace.rash",
          "terminal.posix-compat",
          "terminal.ncurses"
        ],
        "rkconfig": {
          "hostname": "rad",
          "root_password": "rad",
          "rootfs_size_mb": 256,
          "terminal_scale": "auto",
          "terminal_font": "rad-default",
          "terminal_theme": "rad-dark",
          "terminal_autocomplete": true,
          "terminal_posix_compat": true,
          "terminal_ncurses": true,
          "terminal_nano": true,
          "terminal_nano_variant": "both",
          "terminal_vim": true,
          "terminal_vim_variant": "tiny"
        },
        "radpm": {
          "repository": "../RadicalPackages",
          "suite": "experimental",
          "packages": [
            "rad-core",
            "radlib",
            "rad-vim-tiny"
          ]
        },
        "sdk": {
          "enabled": true,
          "name": "rad-sdk-x86_64-grub-terminal.tar.gz",
          "root_name": "rad-sdk-x86_64-grub-terminal"
        },
        "build_dir": "build/embedded/x86_64_grub_terminal",
        "smoke_script": "tools/embedded/x86_64_grub_slint_smoke.sh",
        "artifact_dir": "artifacts/rad/x86_64-grub-terminal",
        "log_dir": ".radmeta/radpx-os/terminal/logs",
        "artifact_names": {
          "kernel": "radkernel-x86-64-grub-terminal",
          "iso": "radkernel-x86-64-grub-terminal.iso",
          "rootfs": "rad-rootfs.ext4",
          "fat32": "rad-fat32.img",
          "serial_log": "x86-64-grub-terminal-smoke.log"
        },
        "qemu_timeout": "90s",
        "qemu_smp": [2],
        "jobs": 2
      }
    },
    {
      "id": "rad-x86-64-grub-wm",
      "type": "os.radix",
      "name": "RADPx-OS x86_64 GRUB RADCompositor WM image",
      "provider": "radix-os",
      "depends_on": [],
      "toolchain": {
        "architecture": "x86_64",
        "boot": "grub-multiboot2",
        "ui": "slint-framebuffer"
      },
      "config": {
        "target": "x86_64-grub-wm",
        "ui_profile": "wm",
        "feature_chunks": [
          "kernel.core",
          "kernel.x86_64",
          "drivers.framebuffer",
          "drivers.input.ps2",
          "drivers.block.virtio",
          "drivers.net.virtio",
          "fs.ext4",
          "fs.fat",
          "services.radinit",
          "services.radcompositor",
          "services.slint-shell",
          "userspace.rash",
          "terminal.posix-compat",
          "terminal.ncurses"
        ],
        "rkconfig": {
          "hostname": "rad",
          "root_password": "rad",
          "rootfs_size_mb": 256,
          "terminal_scale": "auto",
          "terminal_font": "rad-default",
          "terminal_theme": "rad-dark",
          "terminal_autocomplete": true,
          "terminal_posix_compat": true,
          "terminal_ncurses": true,
          "terminal_nano": true,
          "terminal_nano_variant": "both",
          "terminal_vim": true,
          "terminal_vim_variant": "tiny"
        },
        "radpm": {
          "repository": "../RadicalPackages",
          "suite": "experimental",
          "packages": [
            "rad-core",
            "radlib",
            "radlib-ui",
            "rad-vim-tiny"
          ]
        },
        "sdk": {
          "enabled": true,
          "name": "rad-sdk-x86_64-grub-wm.tar.gz",
          "root_name": "rad-sdk-x86_64-grub-wm"
        },
        "build_dir": "build/embedded/x86_64_grub_wm",
        "smoke_script": "tools/embedded/x86_64_grub_slint_smoke.sh",
        "artifact_dir": "artifacts/rad/x86_64-grub-wm",
        "log_dir": ".radmeta/radpx-os/wm/logs",
        "skip_qemu": true,
        "artifact_names": {
          "kernel": "radkernel-x86-64-grub-wm",
          "iso": "radkernel-x86-64-grub-wm.iso",
          "rootfs": "rad-rootfs.ext4",
          "fat32": "rad-fat32.img",
          "serial_log": "x86-64-grub-wm-smoke.log"
        },
        "qemu_timeout": "120s",
        "qemu_smp": [2],
        "jobs": 2
      }
    },
    {
      "id": "rad-zuboard-1cg-serial",
      "type": "os.radix",
      "name": "RADPx-OS ZUBoard 1CG ext4 rootfs serial image",
      "provider": "radix-os",
      "depends_on": [],
      "toolchain": {
        "architecture": "aarch64",
        "boot": "zynqmp-u-boot-bootelf",
        "ui": "serial"
      },
      "config": {
        "target": "zuboard-1cg-rootfs-serial",
        "source": {
          "type": "local",
          "path": "."
        },
        "hardware_source": "auto",
        "board": {
          "vendor": "avnet",
          "name": "zuboard-1cg",
          "part_number": "xczu1cg-sbva484-1-e"
        },
        "board_files": {
          "repository": "https://github.com/Avnet/bdf.git",
          "cache_dir": ".radmeta/xilinx/board_files/avnet-bdf"
        },
        "reference": {
          "xsa": "../ZUBoard-1CG_RT/Vivado/AES_Core/aes128_zynq_interface_wrapper.xsa",
          "psu_init": "../ZUBoard-1CG_RT/Vitis/aes128_zynq_interface_wrapper/hw/psu_init.tcl"
        },
        "uboot": {
          "repository": "https://source.denx.de/u-boot/u-boot.git",
          "source_dir": ".radmeta/sources/u-boot",
          "defconfig": "xilinx_zynqmp_virt_defconfig"
        },
        "boot_chain": {
          "fsbl": "fsbl.elf",
          "pmufw": "pmufw.elf",
          "bl31": "bl31.elf",
          "uboot": "u-boot.elf"
        },
        "run_vivado": false,
        "run_firmware_tools": false,
        "run_uboot_build": false,
        "toolchain_prefix": "../RADLib/.radbuild/toolchains/arm-gnu-toolchain-15.2.rel1-x86_64-aarch64-none-elf/bin/aarch64-none-elf-",
        "uboot_load_address": "0x200000",
        "feature_chunks": [
          "kernel.core",
          "kernel.a53",
          "platform.zynqmp",
          "drivers.serial.ps-uart",
          "drivers.block.zynqmp-sdhci",
          "fs.ext4",
          "services.radinit",
          "userspace.rash",
          "terminal.posix-compat"
        ],
        "rootfs_size_mb": 256,
        "sd_image_boot_mb": 64,
        "build_dir": "tools/embedded/rad_zuboard_1cg",
        "artifact_dir": "artifacts/rad/zuboard-1cg-serial",
        "log_dir": ".radmeta/radpx-os/zuboard/logs",
        "jobs": 2
      }
    },
    {
      "id": "rad-zuboard-1cg-qemu",
      "type": "os.radix",
      "name": "RADPx-OS ZUBoard 1CG QEMU serial image",
      "provider": "radix-os",
      "depends_on": [],
      "toolchain": {
        "architecture": "aarch64",
        "boot": "qemu-loader",
        "ui": "serial"
      },
      "config": {
        "target": "zuboard-1cg-qemu",
        "source": {
          "type": "local",
          "path": "."
        },
        "hardware_source": "auto",
        "qemu": true,
        "qemu_sdhci_base": "0xff160000u",
        "qemu_image_size_mb": 512,
        "board": {
          "vendor": "avnet",
          "name": "zuboard-1cg",
          "part_number": "xczu1cg-sbva484-1-e"
        },
        "board_files": {
          "repository": "https://github.com/Avnet/bdf.git",
          "cache_dir": ".radmeta/xilinx/board_files/avnet-bdf"
        },
        "reference": {
          "xsa": "../ZUBoard-1CG_RT/Vivado/AES_Core/aes128_zynq_interface_wrapper.xsa",
          "psu_init": "../ZUBoard-1CG_RT/Vitis/aes128_zynq_interface_wrapper/hw/psu_init.tcl"
        },
        "uboot": {
          "repository": "https://source.denx.de/u-boot/u-boot.git",
          "source_dir": ".radmeta/sources/u-boot",
          "defconfig": "xilinx_zynqmp_virt_defconfig"
        },
        "boot_chain": {
          "fsbl": "fsbl.elf",
          "pmufw": "pmufw.elf",
          "bl31": "bl31.elf",
          "uboot": "u-boot.elf"
        },
        "run_vivado": false,
        "run_firmware_tools": false,
        "run_uboot_build": false,
        "toolchain_prefix": "../RADLib/.radbuild/toolchains/arm-gnu-toolchain-15.2.rel1-x86_64-aarch64-none-elf/bin/aarch64-none-elf-",
        "uboot_load_address": "0x200000",
        "feature_chunks": [
          "kernel.core",
          "kernel.a53",
          "platform.zynqmp",
          "drivers.serial.ps-uart",
          "drivers.block.zynqmp-sdhci",
          "fs.ext4",
          "services.radinit",
          "userspace.rash",
          "terminal.posix-compat"
        ],
        "rootfs_size_mb": 256,
        "sd_image_boot_mb": 64,
        "build_dir": "tools/embedded/rad_zuboard_1cg",
        "artifact_dir": "artifacts/rad/zuboard-1cg-qemu",
        "log_dir": ".radmeta/radpx-os/zuboard-qemu/logs",
        "jobs": 2
      }
    }
  ],
  "connections": [],
  "artifacts": [],
  "deploy": [],
  "packages": {}
}
