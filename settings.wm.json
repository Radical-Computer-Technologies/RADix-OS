{
  "radbuild_schema": "2.0",
  "radbuild_version": "0.2.1",
  "project_name": "RADPx-OS Window Manager",
  "systems": [
    {
      "id": "rad-x86-64-grub-wm",
      "type": "os.radix",
      "name": "RADPx-OS x86_64 GRUB RADCompositor WM image",
      "provider": "radix-os",
      "depends_on": [],
      "toolchain": {
        "architecture": "x86_64",
        "boot": "grub-multiboot2",
        "ui": "slint-framebuffer"
      },
      "config": {
        "target": "x86_64-grub-wm",
        "ui_profile": "wm",
        "feature_chunks": [
          "kernel.core",
          "kernel.x86_64",
          "drivers.framebuffer",
          "drivers.input.ps2",
          "drivers.block.virtio",
          "drivers.net.virtio",
          "fs.ext4",
          "fs.fat",
          "services.radinit",
          "services.radcompositor",
          "services.slint-shell",
          "userspace.rash",
          "terminal.posix-compat",
          "terminal.ncurses"
        ],
        "rkconfig": {
          "hostname": "rad",
          "root_password": "rad",
          "rootfs_size_mb": 256,
          "terminal_scale": "auto",
          "terminal_font": "rad-default",
          "terminal_theme": "rad-dark",
          "terminal_autocomplete": true,
          "terminal_posix_compat": true,
          "terminal_ncurses": true,
          "terminal_nano": true,
          "terminal_nano_variant": "both",
          "terminal_vim": true,
          "terminal_vim_variant": "tiny"
        },
        "radpm": {
          "repository": "../RadicalPackages",
          "suite": "experimental",
          "packages": [
            "rad-core",
            "radlib",
            "radlib-ui",
            "rad-vim-tiny"
          ]
        },
        "sdk": {
          "enabled": true,
          "name": "rad-sdk-x86_64-grub-wm.tar.gz",
          "root_name": "rad-sdk-x86_64-grub-wm"
        },
        "build_dir": "build/embedded/x86_64_grub_wm",
        "smoke_script": "tools/embedded/x86_64_grub_slint_smoke.sh",
        "artifact_dir": "artifacts/rad/x86_64-grub-wm",
        "log_dir": ".radmeta/radpx-os/wm/logs",
        "skip_qemu": true,
        "artifact_names": {
          "kernel": "radkernel-x86-64-grub-wm",
          "iso": "radkernel-x86-64-grub-wm.iso",
          "rootfs": "rad-rootfs.ext4",
          "fat32": "rad-fat32.img",
          "serial_log": "x86-64-grub-wm-smoke.log"
        },
        "qemu_timeout": "120s",
        "qemu_smp": [2],
        "jobs": 2
      }
    }
  ],
  "connections": [],
  "artifacts": [],
  "deploy": [],
  "packages": {}
}
