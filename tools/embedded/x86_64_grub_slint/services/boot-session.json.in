{
  "name": "boot-session",
  "description": "Primary boot terminal login or autologin session owned by radinit PID1",
  "exec": "@RAD_BOOT_SESSION_EXEC@",
  "args": [],
  "type": "simple",
  "terminal": "/dev/pts/boot-terminal",
  "autostart": true,
  "order": @RAD_BOOT_SESSION_ORDER@,
  "requires": ["base-terminal"],
  "after": [@RAD_BOOT_SESSION_AFTER@],
  "restart": "no",
  "stdout": "/var/log/rad/boot-session.log",
  "stderr": "/var/log/rad/boot-session.log"
}
