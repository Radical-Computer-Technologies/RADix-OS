{
  "name": "dns-resolver",
  "description": "RADPx-OS DNS resolver configuration service",
  "exec": "/sbin/dns-resolver",
  "args": ["/etc/rad/network/dns-resolver.json"],
  "type": "simple",
  "autostart": true,
  "order": 42,
  "requires": ["network"],
  "after": ["network"],
  "restart": "on-failure",
  "ready_marker": "RAD_SERVICE_DNS_RESOLVER_OK",
  "stdout": "/var/log/rad/dns-resolver.log",
  "stderr": "/var/log/rad/dns-resolver.log"
}
