{
  "name": "network",
  "description": "Primary network interface configuration service managed by radinit PID1",
  "exec": "/sbin/network-service",
  "args": ["/etc/rad/network/netinterfaces.json"],
  "type": "simple",
  "autostart": true,
  "order": 40,
  "requires": ["storage-root"],
  "after": ["storage-root"],
  "restart": "no",
  "ready_marker": "RAD_SERVICE_NETWORK_OK",
  "stdout": "/var/log/rad/network.log",
  "stderr": "/var/log/rad/network.log"
}
