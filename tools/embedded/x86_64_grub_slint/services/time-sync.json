{
  "name": "time-sync",
  "description": "RADPx-OS NTP/SNTP realtime clock synchronization service",
  "exec": "/sbin/time-sync",
  "args": ["/etc/rad/time/time-sync.json"],
  "type": "simple",
  "autostart": true,
  "order": 44,
  "requires": ["network", "dns-resolver"],
  "after": ["dns-resolver"],
  "restart": "on-failure",
  "ready_marker": "RAD_SERVICE_TIME_SYNC_OK",
  "stdout": "/var/log/rad/time-sync.log",
  "stderr": "/var/log/rad/time-sync.log"
}
