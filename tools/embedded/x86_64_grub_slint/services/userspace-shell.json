{
  "name": "userspace-shell",
  "description": "RADPx-OS shell self-test and first userspace command service",
  "exec": "/bin/rash",
  "args": ["--selftest"],
  "type": "oneshot",
  "autostart": true,
  "order": 20,
  "requires": ["storage-root"],
  "after": ["storage-root"],
  "restart": "no",
  "stdout": "/var/log/rad/userspace-shell.log",
  "stderr": "/var/log/rad/userspace-shell.log"
}
