{
  "name": "userspace-shell",
  "description": "RADix shell self-test and first userspace command service",
  "exec": "/bin/rash",
  "args": ["--selftest"],
  "autostart": true,
  "order": 20,
  "requires": ["storage-root"],
  "after": ["storage-root"],
  "restart": "no",
  "stdout": "/var/log/radix/userspace-shell.log",
  "stderr": "/var/log/radix/userspace-shell.log"
}
